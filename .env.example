# 环境变量（复制为 .env 填写）
PORT=4000

# LLM（开发阶段用 OpenRouter，生产切 DeepSeek 直连）
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat-v3-0324:free

# 讯飞开放平台（语音，后面再填）
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=

# 数据库（后面再配）
DATABASE_URL=postgresql://uli:uli123@localhost:5432/uli

# Redis（后面再配）
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=uli-dev-secret-change-in-prod
